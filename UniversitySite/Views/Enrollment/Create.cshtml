@model SchoolManagement.Models.Enrollment
@{
    ViewData["Title"] = "Add Enrollment";
}

<div class="page-container">
    <div class="form-card form-card-wide">
        <div class="form-card-header">
            <div class="form-icon"><i class="bi bi-clipboard-plus"></i></div>
            <h2>Add Enrollment</h2>
            <p>Register a student to a course</p>
        </div>

        <form asp-action="Create" method="post" onsubmit="return validateForm();">
            <div class="form-grid">
                <div class="mb-3">
                    <label class="form-label">Student Name *</label>
                    <input asp-for="StudentName" class="form-control" placeholder="Student full name" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Course *</label>
                    <input asp-for="Course" class="form-control" placeholder="Course name" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Semester</label>
                    <input asp-for="Semester" class="form-control" placeholder="e.g. Fall 2025" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Enrollment Date *</label>
                    <input asp-for="EnrollDate" type="date" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Grade</label>
                    <select asp-for="Grade" class="form-control">
                        <option value="">— Not graded yet —</option>
                        <option value="A+">A+</option>
                        <option value="A">A</option>
                        <option value="B+">B+</option>
                        <option value="B">B</option>
                        <option value="C+">C+</option>
                        <option value="C">C</option>
                        <option value="F">F</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Attendance (%)</label>
                    <input asp-for="AttendancePercent" class="form-control" type="number" min="0" max="100" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Status</label>
                    <select asp-for="Status" class="form-control">
                        <option value="Ongoing">Ongoing</option>
                        <option value="Completed">Completed</option>
                        <option value="Dropped">Dropped</option>
                    </select>
                </div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-lg me-1"></i> Add Enrollment
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-x-lg me-1"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function validateForm() {
        const studentname = document.querySelector('[name="StudentName"]').value.trim();
        const course = document.querySelector('[name="Course"]').value.trim();
        const enrolldate = document.querySelector('[name="EnrollDate"]').value.trim();
        if (!studentname || !course || !enrolldate) {
            alert("Student name, course and enrollment date are required.");
            return false;
        }
        return true;
    }
</script>
}
