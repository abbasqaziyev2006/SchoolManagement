@model List<SchoolManagement.Models.Student>

@{
    ViewData["Title"] = "Students";
}

<div class="page-container">
    <div class="page-header">
        <div>
            <h1><i class="bi bi-people-fill"></i> Students</h1>
            <p class="subtitle">View and manage all student records</p>
        </div>
        <a class="btn btn-primary" href="/Student/Create">
            <i class="bi bi-plus-lg me-1"></i> Add New Student
        </a>
    </div>

    <div class="table-card">
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="id-badge">#@item.StudentId</span></td>
                        <td><strong>@item.StudentName</strong></td>
                        <td>@item.Email</td>
                        <td>@item.Phone</td>
                        <td class="action-cell">
                            <a class="btn btn-edit btn-sm" href="/Student/Edit/@item.StudentId">
                                <i class="bi bi-pencil me-1"></i>Edit
                            </a>
                            <a class="btn btn-delete btn-sm" href="/Student/Delete/@item.StudentId" onclick="return confirm('Are you sure?')">
                                <i class="bi bi-trash me-1"></i>Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
