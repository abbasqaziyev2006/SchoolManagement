@model List<SchoolManagement.Models.Student>

@{
    ViewData["Title"] = "Students";
}

<div class="page-container page-container-wide">
    <div class="page-header">
        <div>
            <h1><i class="bi bi-people-fill"></i> Students</h1>
            <p class="subtitle">Entrance score, specialty, annual fee and more</p>
        </div>
        <a class="btn btn-primary" href="/Student/Create">
            <i class="bi bi-plus-lg me-1"></i> Add New Student
        </a>
    </div>

    <div class="summary-cards mb-4">
        <div class="summary-card">
            <i class="bi bi-people"></i>
            <div>
                <span class="summary-value">@Model.Count</span>
                <span class="summary-label">Total students</span>
            </div>
        </div>
        <div class="summary-card">
            <i class="bi bi-graph-up-arrow"></i>
            <div>
                <span class="summary-value">@(Model.Count > 0 ? Math.Round(Model.Average(s => s.EntranceScore), 0) : 0)</span>
                <span class="summary-label">Avg. entrance score</span>
            </div>
        </div>
        <div class="summary-card">
            <i class="bi bi-cash-stack"></i>
            <div>
                <span class="summary-value">$@(Model.Count > 0 ? Math.Round(Model.Average(s => (double)s.AnnualFee), 0) : 0)</span>
                <span class="summary-label">Avg. annual fee</span>
            </div>
        </div>
        <div class="summary-card">
            <i class="bi bi-award"></i>
            <div>
                <span class="summary-value">@Model.Count(s => s.Scholarship != "None")</span>
                <span class="summary-label">Scholarship holders</span>
            </div>
        </div>
    </div>

    <div class="table-card table-scroll">
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Full Name</th>
                    <th>Specialty</th>
                    <th>Entrance Score</th>
                    <th>Annual Fee</th>
                    <th>GPA</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="id-badge">#@item.StudentId</span></td>
                        <td>
                            <strong>@item.StudentName</strong>
                            <small class="d-block text-muted">@item.City</small>
                        </td>
                        <td>@item.Specialty</td>
                        <td><span class="score-badge score-@GetScoreClass(item.EntranceScore)">@item.EntranceScore</span></td>
                        <td><span class="fee-badge">$@item.AnnualFee.ToString("N0")</span></td>
                        <td><span class="gpa-badge">@item.GPA.ToString("0.00")</span></td>
                        <td><span class="status-badge status-active">@item.Status</span></td>
                        <td class="action-cell">
                            <a class="btn btn-info btn-sm text-white" href="/Student/Details/@item.StudentId" title="View">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a class="btn btn-edit btn-sm" href="/Student/Edit/@item.StudentId" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a class="btn btn-delete btn-sm" href="/Student/Delete/@item.StudentId" onclick="return confirm('Are you sure you want to delete this student?')" title="Delete">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@functions {
    string GetScoreClass(double score) => score >= 650 ? "high" : score >= 550 ? "mid" : "low";
}
