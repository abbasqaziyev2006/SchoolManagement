@model List<SchoolManagement.Models.Teacher>

@{
    ViewData["Title"] = "Teachers";
}

<div class="page-container page-container-wide">
    <div class="page-header">
        <div>
            <h1><i class="bi bi-person-badge-fill"></i> Teachers</h1>
            <p class="subtitle">Faculty profiles, departments and experience</p>
        </div>
        <a class="btn btn-primary" href="/Teacher/Create">
            <i class="bi bi-plus-lg me-1"></i> Add New Teacher
        </a>
    </div>

    <div class="table-card table-scroll">
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Department</th>
                    <th>Course</th>
                    <th>Degree</th>
                    <th>Experience</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="id-badge">#@item.TeacherId</span></td>
                        <td>
                            <strong>@item.Name</strong>
                            <small class="d-block text-muted">@item.Email</small>
                        </td>
                        <td>@item.Department</td>
                        <td>@item.Course</td>
                        <td>@item.Degree</td>
                        <td>@item.ExperienceYears yrs</td>
                        <td class="action-cell">
                            <a class="btn btn-edit btn-sm" href="/Teacher/Edit/@item.TeacherId">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a class="btn btn-delete btn-sm" href="/Teacher/Delete/@item.TeacherId" onclick="return confirm('Are you sure?')">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
