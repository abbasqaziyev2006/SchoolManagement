@model List<SchoolManagement.Models.Teacher>

@{
    ViewData["Title"] = "Teachers";
}

<a class="btn btn-primary mt-3 ms-2" href="/Teacher/Create">Add New Teacher</a>

<table class="table table-bordered mt-3">
    <thead>
        <tr>
            <th>TeacherID</th> 
            <th>Name</th>
            <th>Course</th>
            <th>Age</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.TeacherId</td> 
                <td>@item.Name</td>
                <td>@item.Course</td>
                <td>@item.Age</td>
                <td>
                    <a class="btn btn-warning btn-sm" href="/Teacher/Edit/@item.TeacherId">Edit</a>
                    <a class="btn btn-danger btn-sm" href="/Teacher/Delete/@item.TeacherId" onclick="return confirm('Are you sure?')">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
