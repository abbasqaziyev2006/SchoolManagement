@model SchoolManagement.Models.Teacher
@{
    ViewData["Title"] = "Edit Teacher";
}

<div class="page-container">
    <div class="form-card">
        <div class="form-card-header">
            <div class="form-icon"><i class="bi bi-pencil-square"></i></div>
            <h2>Edit Teacher</h2>
            <p>Update teacher information</p>
        </div>

        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="TeacherId" />
            <div class="mb-3">
                <label class="form-label">Name</label>
                <input asp-for="Name" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">Course</label>
                <input asp-for="Course" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">Age</label>
                <input asp-for="Age" class="form-control" type="number" />
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i> Update
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-x-lg me-1"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>
