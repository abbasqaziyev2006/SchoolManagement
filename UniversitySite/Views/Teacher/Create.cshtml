@model SchoolManagement.Models.Teacher
@{
    ViewData["Title"] = "Add Teacher";
}

<div class="page-container">
    <div class="form-card">
        <div class="form-card-header">
            <div class="form-icon"><i class="bi bi-person-badge-fill"></i></div>
            <h2>Add Teacher</h2>
            <p>Register a new faculty member</p>
        </div>

        <form asp-action="Create" method="post" onsubmit="return validateForm();">
            <div class="mb-3">
                <label class="form-label">Name</label>
                <input asp-for="Name" class="form-control" placeholder="Full name" />
            </div>
            <div class="mb-3">
                <label class="form-label">Course</label>
                <input asp-for="Course" class="form-control" placeholder="Assigned course" />
            </div>
            <div class="mb-3">
                <label class="form-label">Age</label>
                <input asp-for="Age" class="form-control" type="number" placeholder="Age" />
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-lg me-1"></i> Add Teacher
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-x-lg me-1"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function validateForm() {
        const name = document.querySelector('[name="Name"]').value.trim();
        const course = document.querySelector('[name="Course"]').value.trim();
        const age = document.querySelector('[name="Age"]').value.trim();

        if (!name || !course || !age) {
            alert("All fields are required: Name, Course, and Age.");
            return false;
        }

        return true;
    }
</script>
}
