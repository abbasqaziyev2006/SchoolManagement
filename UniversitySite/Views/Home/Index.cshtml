@{
    ViewData["Title"] = "Home";
}

<section class="hero text-center">
    <div class="container hero-content">
        <div class="hero-badge">
            <i class="bi bi-stars"></i> Smart Campus Management
        </div>
        <h1>Welcome to UniManage</h1>
        <p class="lead">Manage students, courses, teachers and enrollments — all in one place.</p>
        <a href="/Student" class="btn btn-accent btn-lg me-2">
            <i class="bi bi-rocket-takeoff me-1"></i> Get Started
        </a>
        <a href="/Enrollment" class="btn btn-outline-light btn-lg">
            <i class="bi bi-clipboard-check me-1"></i> View Enrollments
        </a>
    </div>
</section>

<section class="stats-strip">
    <div class="container">
        <div class="row g-4">
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <div class="stat-number"><i class="bi bi-people"></i></div>
                    <div class="stat-label">Students</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <div class="stat-number"><i class="bi bi-book"></i></div>
                    <div class="stat-label">Courses</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <div class="stat-number"><i class="bi bi-person-badge"></i></div>
                    <div class="stat-label">Teachers</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <div class="stat-number"><i class="bi bi-clipboard-check"></i></div>
                    <div class="stat-label">Enrollments</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="container py-5">
    <div class="text-center mb-2">
        <h2 class="section-title">Quick Access</h2>
        <p class="section-subtitle">Choose a module to manage your university records</p>
    </div>
    <div class="row g-4">
        <div class="col-md-6 col-lg-3">
            <div class="feature-card">
                <div class="feature-icon students"><i class="bi bi-people-fill"></i></div>
                <h5>Students</h5>
                <p>Manage student records — names, emails and contact information securely.</p>
                <a href="/Student" class="btn btn-primary w-100">
                    <i class="bi bi-arrow-right-circle me-1"></i> Manage Students
                </a>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="feature-card">
                <div class="feature-icon courses"><i class="bi bi-book-fill"></i></div>
                <h5>Courses</h5>
                <p>Create and update course catalog with names and duration details.</p>
                <a href="/Course" class="btn btn-primary w-100">
                    <i class="bi bi-arrow-right-circle me-1"></i> Manage Courses
                </a>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="feature-card">
                <div class="feature-icon teachers"><i class="bi bi-person-badge-fill"></i></div>
                <h5>Teachers</h5>
                <p>Keep track of faculty members, their courses and profiles.</p>
                <a href="/Teacher" class="btn btn-primary w-100">
                    <i class="bi bi-arrow-right-circle me-1"></i> Manage Teachers
                </a>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="feature-card">
                <div class="feature-icon enroll"><i class="bi bi-clipboard-check-fill"></i></div>
                <h5>Enrollment</h5>
                <p>Register students to courses and track enrollment dates.</p>
                <a href="/Enrollment" class="btn btn-primary w-100">
                    <i class="bi bi-arrow-right-circle me-1"></i> Manage Enrollment
                </a>
            </div>
        </div>
    </div>
</section>
