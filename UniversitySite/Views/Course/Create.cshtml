@model SchoolManagement.Models.Course
@{
    ViewData["Title"] = "Add Course";
}

<div class="page-container">
    <div class="form-card form-card-wide">
        <div class="form-card-header">
            <div class="form-icon"><i class="bi bi-book-half"></i></div>
            <h2>Add Course</h2>
            <p>Add a new course to the university catalog</p>
        </div>

        <form asp-action="Create" method="post" onsubmit="return validateForm();">
            <div class="form-grid">
                <div class="mb-3">
                    <label class="form-label">Course Name *</label>
                    <input asp-for="CourseName" class="form-control" placeholder="e.g. Computer Science" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Department *</label>
                    <input asp-for="Department" class="form-control" placeholder="e.g. Information Technology" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Duration *</label>
                    <input asp-for="Duration" class="form-control" placeholder="e.g. 4 Years" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Credits</label>
                    <input asp-for="Credits" class="form-control" type="number" min="0" placeholder="240" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Language</label>
                    <input asp-for="Language" class="form-control" placeholder="English" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Tuition Fee ($)</label>
                    <input asp-for="TuitionFee" class="form-control" type="number" min="0" step="0.01" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Level</label>
                    <select asp-for="Level" class="form-control">
                        <option value="Bachelor">Bachelor</option>
                        <option value="Master">Master</option>
                        <option value="PhD">PhD</option>
                        <option value="Associate">Associate</option>
                    </select>
                </div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-lg me-1"></i> Add Course
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-x-lg me-1"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function validateForm() {
        const name = document.querySelector('[name="CourseName"]').value.trim();
        const dept = document.querySelector('[name="Department"]').value.trim();
        const duration = document.querySelector('[name="Duration"]').value.trim();
        if (!name || !dept || !duration) {
            alert("Course name, department and duration are required.");
            return false;
        }
        return true;
    }
</script>
}
