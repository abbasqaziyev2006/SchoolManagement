@model SchoolManagement.Models.Course
@{
    ViewData["Title"] = "Edit Course";
}

<div class="page-container">
    <div class="form-card form-card-wide">
        <div class="form-card-header">
            <div class="form-icon"><i class="bi bi-pencil-square"></i></div>
            <h2>Edit Course</h2>
            <p>Update course details</p>
        </div>

        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="CourseId" />
            <div class="form-grid">
                <div class="mb-3">
                    <label class="form-label">Course Name</label>
                    <input asp-for="CourseName" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Department</label>
                    <input asp-for="Department" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Duration</label>
                    <input asp-for="Duration" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Credits</label>
                    <input asp-for="Credits" class="form-control" type="number" min="0" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Language</label>
                    <input asp-for="Language" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Tuition Fee ($)</label>
                    <input asp-for="TuitionFee" class="form-control" type="number" min="0" step="0.01" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Level</label>
                    <select asp-for="Level" class="form-control">
                        <option value="Bachelor">Bachelor</option>
                        <option value="Master">Master</option>
                        <option value="PhD">PhD</option>
                        <option value="Associate">Associate</option>
                    </select>
                </div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i> Update
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-x-lg me-1"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>
